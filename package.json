{
  "name": "ecristonhistoire",
  "version": "0.1.3",
  "description": "Application d'écriture - personnages et développement narratif",
  "author": "Krystiinal",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "start": "electron .",
    "dist": "vite build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder"
  },
  "build": {
    "appId": "com.ecristonhistoire.app",
    "productName": "EcrisTonHistoire",
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/.bin/**/*",
      "!documents_bdd/**/*",
      "!script_chronologie.jsx"
    ],
    "publish": {
      "provider": "github",
      "owner": "Krystiinal",
      "repo": "EcrisTonHistoire"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@tiptap/extension-character-count": "^2.0.0",
    "@tiptap/extension-font-family": "^2.0.0",
    "@tiptap/extension-highlight": "^2.0.0",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-subscript": "^2.27.2",
    "@tiptap/extension-superscript": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/extension-text-align": "^2.0.0",
    "@tiptap/extension-text-style": "^2.0.0",
    "@tiptap/extension-underline": "^2.0.0",
    "@tiptap/pm": "^2.0.0",
    "@tiptap/starter-kit": "^2.0.0",
    "@tiptap/vue-3": "^2.0.0",
    "docx": "^9.6.1",
    "electron-updater": "^6.8.3",
    "node-html-parser": "^7.1.0",
    "sql.js": "^1.12.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.0",
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.2",
    "to-ico": "^1.1.5",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  }
}